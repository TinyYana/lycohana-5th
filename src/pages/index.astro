---
import "../styles/global.css";

import SEO from "../components/SEO.astro";
import { achievementRoles, animePicks, colorRoles, futureProjects, memoryMessages, siteCopy, timeline } from "../lib/site-data";
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400&family=Noto+Serif+TC:wght@500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="site-shell">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-inner">
          <div class="hero-copy">
            <p class="hero-mark">
              <span>彼岸花社群</span>
              <span>五週年</span>
            </p>
            <h1 id="hero-title" class="hero-title">{siteCopy.heroTitle}</h1>
            <p class="hero-subtitle">{siteCopy.heroSubtitle}</p>
            <p class="hero-description">{siteCopy.heroDescription}</p>
            <div class="hero-stickers" aria-label="社群資訊">
              <p class="founded-note">
                <span>建立日期</span>
                <strong>{siteCopy.foundedAt}</strong>
              </p>
              {siteCopy.discordInviteUrl && (
                <p class="discord-note">
                  <span>如果你是從這頁才知道這裡</span>
                  <a href={siteCopy.discordInviteUrl} target="_blank" rel="noreferrer">{siteCopy.discordInviteLabel}</a>
                </p>
              )}
            </div>
          </div>

          <aside class="hero-scrap" aria-label="彼岸花剪貼簿裝飾">
            <img class="lycoris-mark" src="/lycoris-mark.svg" alt="彼岸花線稿" />
            <p class="scrap-caption">這不是什麼大型活動，只是我把五年裡留下來的一些東西收一收，整理成一本可以慢慢翻的剪貼簿。</p>
          </aside>
        </div>
      </section>

      <section class="section" aria-labelledby="colors-title">
        <div class="section-inner">
          <header class="section-header">
            <p class="section-kicker">Color Roles</p>
            <h2 id="colors-title" class="section-title">花海色彩</h2>
            <p class="section-note">就是大家現在把名字染成什麼顏色。老實說這種統計沒什麼實際用途，但看一眼會知道：喔，原來這裡是這種色調的地方。</p>
          </header>

          {colorRoles.length > 0 ? (
            <div class="role-grid">
              {colorRoles.map((role) => (
                <article class="role-card">
                  <div class="color-swatch" style={`background: ${role.color}`} aria-hidden="true"></div>
                  <div>
                    <div class="card-title-row">
                      <h3 class="card-title">{role.name}</h3>
                      <span class="member-count">{role.memberCount} 人</span>
                    </div>
                    <p class="card-description">{role.description}</p>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <p class="empty-state">顏色身分組的 snapshot 我還沒跑。資料丟進來之後，這一區會自己長出來。</p>
          )}
        </div>
      </section>

      <section class="section" aria-labelledby="badges-title">
        <div class="section-inner">
          <header class="section-header">
            <p class="section-kicker">Achievement Roles</p>
            <h2 id="badges-title" class="section-title">紀念徽章</h2>
            <p class="section-note">有些是紀念性質，有些其實只是功能型身分組。不是每一枚都很重要，但每一枚都對得上某段時間發生過的事。</p>
          </header>

          {achievementRoles.length > 0 ? (
            <div class="badge-grid">
              {achievementRoles.map((role) => (
                <article class="badge-card">
                  <span class="badge-year">{role.year ?? "年份待補"}</span>
                  <div class="card-title-row">
                    <h3 class="card-title">{role.name}</h3>
                    <span class="member-count">{role.memberCount} 人</span>
                  </div>
                  <p class="card-description">{role.description}</p>
                </article>
              ))}
            </div>
          ) : (
            <p class="empty-state">徽章背後的故事我還在整理，這一區先空著等。</p>
          )}
        </div>
      </section>

      <section class="section" aria-labelledby="timeline-title">
        <div class="section-inner">
          <header class="section-header">
            <p class="section-kicker">Timeline</p>
            <h2 id="timeline-title" class="section-title">社群年表</h2>
            <p class="section-note">我沒打算寫完整社群史，先把翻公告能確認的節點放上來，剩下的想起來再補。</p>
          </header>

          {timeline.length > 0 ? (
            <div class="timeline">
              {timeline.map((item) => (
                <article class="timeline-item">
                  <p class="timeline-year">{item.year}</p>
                  <h3 class="timeline-title">{item.title}</h3>
                  <p class="timeline-description">{item.description}</p>
                </article>
              ))}
            </div>
          ) : (
            <p class="empty-state">年表還是空的。我會把 2021 到 2026 的片段慢慢放回來。</p>
          )}
        </div>
      </section>

      <section class="section" aria-labelledby="anime-title">
        <div class="section-inner">
          <header class="section-header">
            <p class="section-kicker">Anime Picks</p>
            <h2 id="anime-title" class="section-title">動畫推薦</h2>
            <p class="section-note">動畫推薦頻道斷更很久了，這件事我自己也知道。這裡放幾部斷更之後看的、真心覺得可以推的，描述就簡單寫寫，當作把進度補上。</p>
          </header>

          {animePicks.length > 0 ? (
            <div class="anime-grid">
              {animePicks.map((pick) => (
                <article class="anime-card">
                  {pick.imageSrc && (
                    <figure class="anime-figure">
                      <img class="anime-image" src={pick.imageSrc} alt={pick.imageAlt} loading="lazy" />
                    </figure>
                  )}
                  <div class="anime-card-body">
                    <h3 class="card-title">{pick.title}</h3>
                    {pick.meta && <p class="anime-meta">{pick.meta}</p>}
                    <p class="card-description">{pick.description}</p>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <p class="empty-state">片單還沒放上來。等我把最近看的整理一下。</p>
          )}
        </div>
      </section>

      <section class="section" aria-labelledby="messages-title">
        <div class="section-inner">
          <header class="section-header">
            <p class="section-kicker">Memory Wall</p>
            <h2 id="messages-title" class="section-title">回憶留言牆</h2>
            <p class="section-note">把這裡想成神社的繪馬牆就好：留言板開放後，你寫的話會一塊一塊掛上來。只放你同意公開的內容，想匿名也可以，跟我說一聲就好。</p>
          </header>

          {memoryMessages.length > 0 ? (
            <div class="message-wall">
              {memoryMessages.map((message) => (
                <article class="message-card">
                  <blockquote class="message-content">{message.content}</blockquote>
                  <p class="message-author">— {message.displayName}</p>
                </article>
              ))}
            </div>
          ) : (
            <p class="empty-state">牆上還沒有掛任何一塊。等留言板開放，第一塊就會出現在這裡。</p>
          )}
        </div>
      </section>

      <section class="section" aria-labelledby="future-title">
        <div class="section-inner">
          <header class="section-header">
            <p class="section-kicker">Future Notes</p>
            <h2 id="future-title" class="section-title">未來坑洞</h2>
            <p class="section-note">之後彼岸花會慢慢往「讓大家待得舒服」這個方向走。具體要怎麼做我還在想，所以這一區先誠實地叫坑洞。</p>
          </header>

          {futureProjects.length > 0 ? (
            <div class="future-list">
              {futureProjects.map((project) => (
                <article class="future-item">
                  <div class="future-item-head">
                    <h3 class="card-title">{project.title}</h3>
                    <span class="future-status">{project.status}</span>
                  </div>
                  <p class="card-description">{project.description}</p>
                </article>
              ))}
            </div>
          ) : (
            <p class="empty-state">坑還沒列出來。也可能這是好事。</p>
          )}
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>{siteCopy.footerText}</p>
    </footer>

    <script>
      // 捲動顯示：尊重 prefers-reduced-motion，無 JS 時所有內容照常顯示。
      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!prefersReduced && "IntersectionObserver" in window) {
        const targets = document.querySelectorAll<HTMLElement>(
          ".section-header, .role-card, .badge-card, .timeline-item, .anime-card, .message-card, .future-item, .empty-state"
        );

        const settle = (el: HTMLElement) => {
          el.classList.remove("reveal", "is-visible");
          el.style.removeProperty("--reveal-delay");
        };

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              const el = entry.target as HTMLElement;
              observer.unobserve(el);
              el.classList.add("is-visible");
              // 過場結束後移除 reveal class，讓卡片的 hover 過渡恢復正常
              const delay = Number.parseInt(el.style.getPropertyValue("--reveal-delay")) || 0;
              window.setTimeout(() => settle(el), 700 + delay);
            }
          },
          { threshold: 0.15, rootMargin: "0px 0px -40px 0px" }
        );

        const siblingIndex = new Map<HTMLElement, number>();
        for (const el of targets) {
          const parent = el.parentElement;
          if (!parent) continue;
          const index = siblingIndex.get(parent) ?? 0;
          siblingIndex.set(parent, index + 1);
          el.style.setProperty("--reveal-delay", `${Math.min(index, 5) * 70}ms`);
          el.classList.add("reveal");
          observer.observe(el);
        }
      }
    </script>
  </body>
</html>
