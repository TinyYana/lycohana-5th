---
// 共用 SEO meta tags。各頁面只放一次，內容可用 props 覆寫。
const siteUrl = "https://lycohana5th.tinyyana.com";

interface Props {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title = "彼岸花ACG Discord社群 五週年紀念館",
  description = "2021/06/28 22:48，彼岸花ACG Discord社群（LycoHana）建立。五年了，這裡還在。這是一個記錄彼岸花社群五年痕跡的紀念網站。",
  url = `${siteUrl}/`,
  image = `${siteUrl}/og-image.png`,
  imageAlt = "彼岸花ACG Discord社群 五週年紀念館預覽圖"
} = Astro.props;
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={url} />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#D6B36A" />
<meta name="author" content="TinyYana" />
<meta name="language" content="zh-Hant" />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={url} />
<meta property="og:image" content={image} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:site_name" content="彼岸花ACG Discord社群" />
<meta property="og:locale" content="zh_TW" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />
<meta name="twitter:image:alt" content={imageAlt} />
