---
// 共用 SEO meta tags。各頁面只放一次，內容可用 props 覆寫。
const siteUrl = "https://lycohana5th.tinyyana.com";

interface Props {
  title?: string;
  description?: string;
  url?: string;
  image?: string;
  imageAlt?: string;
}

const {
  title = "彼岸花ACG Discord社群 五週年紀念館",
  description = "2021/06/28 建立的台灣 ACG Discord 社群「彼岸花」（LycoHana）五週年紀念網站。收錄社群色彩身分組、紀念徽章、社群年表與成員回憶留言，記錄五年來走過的痕跡。",
  url = `${siteUrl}/`,
  image = `${siteUrl}/og-image.png`,
  imageAlt = "彼岸花ACG Discord社群 五週年紀念館預覽圖"
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "彼岸花ACG Discord社群 五週年紀念館",
      "url": siteUrl,
    },
    {
      "@type": "Organization",
      "name": "彼岸花ACG Discord社群",
      "alternateName": ["LycoHana", "彼岸花社群"],
      "url": siteUrl,
      "logo": `${siteUrl}/apple-touch-icon.png`,
      "foundingDate": "2021-06-28",
      "description": "台灣 ACG（動漫、遊戲、漫畫）主題 Discord 社群，2021 年建立，以彼岸花為社群意象。",
      "sameAs": ["https://discord.gg/nMAz72MUxv"],
    },
  ],
};
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content="彼岸花社群, LycoHana, 彼岸花ACG, Discord社群, ACG, 動漫, 遊戲, 漫畫, 五週年, 台灣Discord, 彼岸花" />
<link rel="canonical" href={url} />
<link rel="icon" href="/favicon.png" type="image/png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#D6B36A" />
<meta name="author" content="TinyYana" />
<meta name="language" content="zh-Hant" />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={url} />
<meta property="og:image" content={image} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:site_name" content="彼岸花ACG Discord社群" />
<meta property="og:locale" content="zh_TW" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />
<meta name="twitter:image:alt" content={imageAlt} />

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
